{
	"compilerOptions": {
		"skipLibCheck": true,
		"skipDefaultLibCheck": true,
		"target": "es2015",
		"module": "commonjs",
		"rootDir": "src",
		"outDir": "dist",
		"sourceMap": true,
		"declaration": true,
		"resolveJsonModule": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules", "src/old/*"]
}
